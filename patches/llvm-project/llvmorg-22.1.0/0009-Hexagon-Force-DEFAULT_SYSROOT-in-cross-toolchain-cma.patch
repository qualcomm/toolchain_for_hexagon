From 70c01494cd3cb960a21694b7fe22b0fc22da7328 Mon Sep 17 00:00:00 2001
From: Brian Cain <brian.cain@oss.qualcomm.com>
Date: Sun, 1 Mar 2026 13:26:28 -0800
Subject: [PATCH 09/15] [Hexagon] Force DEFAULT_SYSROOT in cross-toolchain
 cmake cache
Content-Type: text/plain; charset="utf-8"
Content-Transfer-Encoding: 8bit

When obj_llvm has a stale CMakeCache.txt from a prior configuration,
the CACHE STRING "" on DEFAULT_SYSROOT is silently ignored because
cmake -C will not overwrite an existing cached value.  This causes
DEFAULT_SYSROOT to remain empty, which makes the cross-compiler unable
to find system headers:

  fatal error: 'stdlib.h' file not found
  fatal error: 'sys/mman.h' file not found

These appear during build_clang_rt_builtins and any other step that
uses the cross-compiler before a manual cache clean.

Add FORCE so the sysroot path is always applied regardless of prior
cache state.
---
 clang/cmake/caches/hexagon-unknown-linux-musl-clang-cross.cmake | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/clang/cmake/caches/hexagon-unknown-linux-musl-clang-cross.cmake b/clang/cmake/caches/hexagon-unknown-linux-musl-clang-cross.cmake
index e6b4e8c047b3..ee7ee512d94a 100644
--- a/clang/cmake/caches/hexagon-unknown-linux-musl-clang-cross.cmake
+++ b/clang/cmake/caches/hexagon-unknown-linux-musl-clang-cross.cmake
@@ -1,6 +1,6 @@
 # This file is for the llvm+clang options that are specific to building
 # a cross-toolchain targeting hexagon linux.
-set(DEFAULT_SYSROOT "../target/hexagon-unknown-linux-musl/" CACHE STRING "")
+set(DEFAULT_SYSROOT "../target/hexagon-unknown-linux-musl/" CACHE STRING "" FORCE)
 set(CLANG_LINKS_TO_CREATE
             hexagon-linux-musl-clang++
             hexagon-linux-musl-clang
